{
  "manifest_version": 3,
  "name": "Raja Browser Pro",
  "version": "1.0.0",
  "description": "Advanced Web Engine with Built-in AI, Hardcore Ad-Blocker, and Turbo Speed. System Architect: Rajaram.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "contextMenus",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "Worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Raja Control Center"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["script.js", "main.js"],
      "run_at": "document_start"
    }
  ]
}
